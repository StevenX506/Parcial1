@model Parcial1.Models.Partido
@using Parcial1.Models

@{
    ViewData["Title"] = "Crear partido";
    var equipos = ViewBag.Equipos as List<Equipo> ?? new List<Equipo>();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Crear partido</h2>
        <a href="/Torneo/Detalle/@Model.TorneoId" class="btn btn-secondary">Volver</a>
    </div>

    <form action="/Partido/Crear" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TorneoId" value="@Model.TorneoId" />

        <div class="mb-3">
            <label class="form-label">Equipo local</label>
            <select name="EquipoLocalId" class="form-select">
                <option value="">-- Seleccionar --</option>
                @foreach (var equipo in equipos)
                {
                    <option value="@equipo.Id">@equipo.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Equipo visitante</label>
            <select name="EquipoVisitanteId" class="form-select">
                <option value="">-- Seleccionar --</option>
                @foreach (var equipo in equipos)
                {
                    <option value="@equipo.Id">@equipo.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Fecha del partido</label>
            <input name="FechaPartido" class="form-control" type="date" />
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0">@error.ErrorMessage</p>
                }
            </div>
        }

        <button type="submit" class="btn btn-primary">Crear partido</button>
    </form>
</div>