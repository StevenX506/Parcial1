@model Parcial1.Models.Partido
@using Parcial1.Models
@{
    ViewData["Title"] = "Definir penales";
    var local = ViewBag.Local as Equipo;
    var visitante = ViewBag.Visitante as Equipo;
}

<div class="page">
    <div class="card-box">
        <h3 class="mb-3">Empate</h3>

        <div class="empate-badge">
            Resultado: @Model.GolesLocal - @Model.GolesVisitante
        </div>

        <form action="/Partido/Penales" method="post" class="text-start">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="torneoId" value="@ViewBag.TorneoId" />

            <div class="mb-3">
                <label class="form-label">¿Quién ganó en penales?</label>
                <select name="ganadorId" class="form-select">
                    <option value="@local?.Id">@local?.Nombre</option>
                    <option value="@visitante?.Id">@visitante?.Nombre</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">Guardar ganador</button>
        </form>
    </div>
</div>