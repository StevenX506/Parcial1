@model Parcial1.Models.Torneo

@{
    ViewData["Title"] = "Crear torneo";
}

<div class="page">

    <div class="card-box">

        <div class="header">
            <h3>Crear torneo</h3>
            <a href="/Torneo/Index" class="btn btn-secondary btn-sm">
                Volver
            </a>
        </div>

        <form action="/Torneo/Crear" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" name="Activo" value="true" />

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input name="Nombre"
                       class="form-control"
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label">Edición</label>
                <input name="Edicion"
                       class="form-control"
                       type="number"
                       required />
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Crear torneo
            </button>

        </form>

    </div>

</div>