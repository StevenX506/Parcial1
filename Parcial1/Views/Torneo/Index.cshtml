@model List<Parcial1.Models.Torneo>

@{
    ViewData["Title"] = "Torneos";
}

<div class="page">

    <div class="header">
        <div>
            <h3>Torneos</h3>
            <small class="text-muted">Gestión de mini torneos</small>
        </div>
        <a href="/Torneo/Crear" class="btn btn-primary">+ Nuevo torneo</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-light border text-danger mb-3">@TempData["Error"]</div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-light border">No hay torneos registrados.</div>
    }
    else
    {
        <div class="table-box">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Creado</th>
                        <th>Edición</th>
                        <th>Estado</th>
                        <th style="width:300px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var torneo in Model)
                    {
                     <tr>
                     <td><strong>@torneo.Nombre</strong></td>
                     <td>@torneo.CreadoEn.ToString("dd/MM/yyyy")</td>
                     <td>@torneo.Edicion</td>
                     <td>
                            @if (torneo.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Finalizado</span>
                                }
                            </td>
                            <td>
                                <div class="actions">
                                    <a href="/Torneo/Detalle/@torneo.Id" class="btn btn-sm btn-open">Abrir</a>
                                    <a href="/Torneo/Editar/@torneo.Id" class="btn btn-sm btn-edit">Editar</a>

                                    @if (torneo.Activo)
                                    {
                                        <form action="/Torneo/Desactivar" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@torneo.Id" />
                                            <button class="btn btn-sm btn-danger-soft"
                                                    onclick="return confirm('¿Finalizar este torneo?')">
                                                Finalizar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form action="/Torneo/Activar" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@torneo.Id" />
                                            <button class="btn btn-sm btn-open">Activar</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>