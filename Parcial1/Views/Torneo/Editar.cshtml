@model Parcial1.Models.Torneo

@{
    ViewData["Title"] = "Editar torneo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Editar torneo</h2>
        <a href="/Torneo/Index" class="btn btn-secondary">Volver</a>
    </div>

    <form action="/Torneo/Editar" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input name="Nombre" value="@Model.Nombre" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Edición</label>
            <input name="Edicion" value="@Model.Edicion" class="form-control" type="number" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </form>
</div>