@model Parcial1.Models.Torneo

@{
    ViewData["Title"] = "Editar torneo";
}

<div class="page">

    <div class="card-box">

        <div class="header">
            <h3>Editar torneo</h3>
            <a href="/Torneo/Index" class="btn btn-secondary btn-sm">
                Volver
            </a>
        </div>

        <form action="/Torneo/Editar" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input name="Nombre"
                       value="@Model.Nombre"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Edición</label>
                <input name="Edicion"
                       value="@Model.Edicion"
                       class="form-control"
                       type="number" />
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Guardar cambios
            </button>

        </form>

    </div>

</div>