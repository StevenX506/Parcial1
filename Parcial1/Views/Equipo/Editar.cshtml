@model Parcial1.Models.Equipo

@{
    ViewData["Title"] = "Editar equipo";
}

<div class="page">
    <div class="card-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3>Editar equipo</h3>
            <a href="/Torneo/Detalle/@Model.TorneoId" class="btn btn-secondary btn-sm">Volver</a>
        </div>

        <form action="/Equipo/Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="TorneoId" value="@Model.TorneoId" />

            <div class="mb-3">
                <label class="form-label">Nombre del equipo</label>
                <input type="text" name="Nombre" value="@Model.Nombre" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Ciudad</label>
                <input type="text" name="Ciudad" value="@Model.Ciudad" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Guardar cambios</button>
        </form>

    </div>
</div>